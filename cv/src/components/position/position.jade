link(rel="import" href="../3rdparty/polymer.html")
link(rel="import" href="../markdown/markdown.html")
  
dom-module#comp-position
  template
    style !{readFile('position.css')}
        
    .summary
      // .action.fa(class$="{{ isExtended() ? 'fa-level-up' : 'fa-level-down' }}")
      .title {{ data.position }}
      .company {{ data.company }}
      .sub
        .location {{ data.location }}
        .fromto {{ getDate(data) }}
      .year '{{ getShortYear(data) }}
    comp-markdown.expanded(text="{{ data.description }}")
      
  script !{readFile('position.js')}
